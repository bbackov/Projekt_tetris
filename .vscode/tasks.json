{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "build tetris",
        "type": "shell",
        "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
        "args": [
          "-std=c++17",
          "-g",
  
          "src\\main.cpp",
          "src\\glad.c",
  
          "src\\game\\Game.cpp",
          "src\\board\\Board.cpp",
          "src\\blocks\\Blocks.cpp",
          "src\\blocks\\Factory.cpp",
          "src\\input\\input.cpp",
          "src\\util\\shader.cpp",
  
          "-Iinclude",
          "-Isrc",
  
          "-Llibs",
          "-lglfw3",
          "-lopengl32",
          "-lgdi32",
  
          "-o",
          "Tetris.exe"
        ],
        "options": {
          "cwd": "${workspaceFolder}"
        },
        "problemMatcher": [
          "$gcc"
        ],
        "group": {
          "kind": "build",
          "isDefault": true
        }
      }
    ]
  }